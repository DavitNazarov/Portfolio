PORT=3000
MONGO_URI=mongodb+srv://user:pass@cluster.mongodb.net/?appName=Portfolio
JWT_SECRET=your-secret-key
FRONTEND_URL=http://localhost:5173
ALLOW_PUBLIC_REGISTRATION=false
